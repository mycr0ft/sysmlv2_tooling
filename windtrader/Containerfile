FROM python:3.12-slim

LABEL maintainer="sysml2-tools"
LABEL description="Windtrader - SysML v2 validation wrapper using official Java validator"

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    default-jre-headless \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir git+https://github.com/Westfall-io/windtrader.git

WORKDIR /workspace

ENTRYPOINT ["windtrader"]
CMD ["--help"]