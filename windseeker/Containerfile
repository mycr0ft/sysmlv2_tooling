FROM python:3.12-slim

LABEL maintainer="sysml2-tools"
LABEL description="Windseeker - SysML v2 dependency analysis, notebook generation, and view extraction tool"

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    libcairo2-dev \
    libffi-dev \
    libgirepository1.0-dev \
    libglib2.0-dev \
    libmariadb-dev \
    libpq-dev \
    libsoup-3.0-dev \
    libxext-dev \
    libxrender-dev \
    libgdk-pixbuf-2.0-dev \
    shared-mime-info \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir sysml-windseeker

WORKDIR /workspace

ENTRYPOINT ["windseeker"]
CMD ["--help"]